# Recommended hackathon/default LLM provider.
# If you need a fully offline run, set LLM_PROVIDER=disabled in your local .env.
LLM_PROVIDER=yandex

# Yandex AI Studio / Model Gallery. Keep secrets in .env or local api.txt, never in git.
# Best current default for final SelTox llm-extract: qwen3.6-35b-a3b/latest.
# Cheap/fast smoke fallback: deepseek-v4-flash.
# Also smoke-tested: aliceai-llm-flash, qwen3-235b-a22b-fp8.
# Avoid as default for now: gpt-oss-120b, gpt-oss-20b.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_API_KEY_FILE=api.txt

# For OpenAI-compatible APIs, including many proxy/self-hosted gateways.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ai.api.cloud.yandex.net/v1
LLM_MODEL=qwen3.6-35b-a3b/latest
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=16384

# Optional: local cache for official ChemX gold tables.
CHEMX_GOLD_DIR=data/gold
