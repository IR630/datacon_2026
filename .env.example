# LLM is disabled by default; the deterministic parser/evidence/evaluator work without it.
# Set LLM_PROVIDER=yandex for Yandex AI Studio / Model Gallery.
LLM_PROVIDER=disabled

# Yandex AI Studio / Model Gallery. Keep secrets in .env or local api.txt, never in git.
# Recommended first paid-per-token model for SelTox smoke runs: deepseek-v4-flash.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_API_KEY_FILE=api.txt

# For OpenAI-compatible APIs, including many proxy/self-hosted gateways.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ai.api.cloud.yandex.net/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=1024

# Optional: local cache for official ChemX gold tables.
CHEMX_GOLD_DIR=data/gold
